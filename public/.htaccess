<IfModule mod_rewrite.c> 
    RewriteEngine On
    RewriteBase /
    # Ignorar archivos y carpetas existentes
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]
    # Enviar todo lo demás a index.php
    RewriteRule ^ index.php [QSA,L]
</IfModule>